<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — Compose handles everything, this is just for the window/status bar -->
    <style name="Theme.YouMe" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme (shown before Compose loads) -->
    <style name="Theme.YouMe.SplashScreen" parent="Theme.YouMe">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>
